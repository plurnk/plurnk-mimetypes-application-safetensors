{
    "name": "@plurnk/plurnk-mimetypes-application-safetensors",
    "version": "0.1.7",
    "description": "application/x-safetensors (safetensors model weights) mimetype handler for plurnk-service. Reads the JSON header into a tensor inventory without loading weights. Hand-rolled, no parser dependency.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "plurnk": {
        "kind": "mimetype",
        "binary": true,
        "handlers": [
            {
                "name": "application/x-safetensors",
                "glyph": "🔢",
                "extensions": [
                    ".safetensors"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build && (git config core.hooksPath .githooks || true)",
        "deps:fresh": "npm outdated",
        "prepublishOnly": "npm run deps:fresh && npm audit --audit-level=moderate && npm test"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "typescript": "^7.0.2",
        "@plurnk/plurnk-mimetypes": "^1"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^1"
    }
}
